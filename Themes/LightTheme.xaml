<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush x:Key="BackgroundBrush" Color="#F0F4F8"/>
    <SolidColorBrush x:Key="CardBrush" Color="White"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="AltRowBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="ActionColumnBrush" Color="#F8FAFC"/>

    <SolidColorBrush x:Key="TableRowBrush" Color="White"/>

    <SolidColorBrush x:Key="SubTextBrush" Color="#6B7280"/>



    <SolidColorBrush x:Key="InputBrush" Color="#F9FAFB"/>
    <!-- Texto -->
    <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
   

    <!-- Bordes -->
    <SolidColorBrush x:Key="BorderBrushCustom" Color="#E5E7EB"/>

    <SolidColorBrush x:Key="ActionButtonBackgroundBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ActionButtonHoverBrush" Color="#F3F4F6"/>

    <SolidColorBrush x:Key="InputTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#9CA3AF"/>

</ResourceDictionary>