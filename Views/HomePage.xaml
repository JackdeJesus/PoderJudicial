<Page x:Class="PoderJudicial.Views.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Poder Judicial Guatemala"
          UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Page.Resources>
        <!-- ===== COLORS ===== -->
        <!-- SidebarBg: #1A2744 | AccentBlue: #2563EB | CardWhite: #FFFFFF -->
        <!-- TextDark: #1E293B  | TextMid: #64748B   | GreenStat: #16A34A -->
        <!-- OrangeStat: #EA580C | PurpleStat: #7C3AED | TealStat: #0D9488 -->





        <!-- ===== QUICK-ACCESS CARD STYLE ===== -->
        <Style x:Key="QuickCardStyle" TargetType="Border">
            <Setter Property="Background"
            Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"
            Value="{DynamicResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness"
            Value="1"/>
            <Setter Property="CornerRadius"
            Value="12"/>
            <Setter Property="Padding"
            Value="20"/>
            <Setter Property="Margin"
            Value="0,0,12,0"/>
            <Setter Property="Height"
            Value="230"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                              Opacity="0.18"
                              BlurRadius="18"
                              ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STAT CARD STYLE ===== -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background"
            Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"
            Value="{DynamicResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness"
            Value="1"/>
            <Setter Property="CornerRadius"
            Value="12"/>
            <Setter Property="Padding"
            Value="20"/>
            <Setter Property="Margin"
            Value="0,0,12,0"/>
            <Setter Property="Height"
            Value="170"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                              Opacity="0.18"
                              BlurRadius="18"
                              ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ICON CIRCLE STYLE ===== -->
        <Style x:Key="IconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SystemCardStyle" TargetType="Border">
            <Setter Property="Background"
    Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"
    Value="{DynamicResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness"
    Value="1"/>
            <Setter Property="CornerRadius"
    Value="12"/>
            <Setter Property="Padding"
    Value="20"/>
            <Setter Property="Margin"
    Value="0,0,0,0"/>
            <Setter Property="Height"
    Value="230"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                      Opacity="0.18"
                      BlurRadius="18"
                      ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>





    <Grid>



        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="17*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>

            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <!-- ══════════════════════════════════════════
             MAIN AREA
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <!-- Top bar -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════
         HEADER
     ══════════════════════════════════ -->

            <Border Grid.Row="0"
Background="{DynamicResource CardBrush}"
BorderThickness="0,0,0,1"
BorderBrush="{DynamicResource BorderBrush}"
Padding="32,18"
        Margin="0,0,0,30">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Panel Principal"
               FontSize="22"
               FontWeight="Bold"
               Foreground="{DynamicResource PrimaryTextBrush}"/>

                        <TextBlock Text="SSistema de Control de Audiencias y Copias"
               FontSize="12"
               Foreground="{DynamicResource SecondaryTextBrush}"
               Margin="0,3,0,0"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1"
            HorizontalAlignment="Right">

                        <TextBlock x:Name="TxtHora"
               FontSize="22"
               FontWeight="Bold"
               Foreground="{DynamicResource PrimaryTextBrush}"
               HorizontalAlignment="Right"/>

                        <TextBlock x:Name="TxtFecha"
               FontSize="12"
               Foreground="{DynamicResource SecondaryTextBrush}"
               HorizontalAlignment="Right"
               Margin="0,2,0,0"/>

                    </StackPanel>

                </Grid>

            </Border>



            <!-- ── SCROLLABLE CONTENT ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,24">

                    <!-- ── WELCOME BANNER ── -->
                    <Border CornerRadius="14" Margin="0,0,0,24" ClipToBounds="True">
                        <Grid>
                            <!-- Gradient background -->
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#EFF6FF" Offset="0"/>
                                        <GradientStop Color="#DBEAFE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto" MinWidth="198"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left: text + accent bar -->
                                <Grid Grid.Column="0">
                                    <Border Width="4" Background="#2563EB"
                                            HorizontalAlignment="Left"
                                            CornerRadius="4,0,0,4"/>
                                    <StackPanel Margin="24,24,24,24">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="¡Bienvenido! " FontSize="28"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="👋" FontSize="26"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Sistema de gestión y control de audiencias, ejecuciones y copias."
                                                   Foreground="#475569" FontSize="16"
                                                   Margin="0,6,0,2"/>
                                        <TextBlock Text="Seleccione una opción del menú para comenzar."
                                                   Foreground="#475569" FontSize="16"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Right: courthouse illustration placeholder -->
                                <Border Grid.Column="1" Height="120"
                                        Margin="4,0,29,0" VerticalAlignment="Center"
                                        Opacity="0.25">
                                    <TextBlock Text="🏛" FontSize="120"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── ACCESO RÁPIDO ── -->
                    <TextBlock Text="ACCESO RÁPIDO"
                               Foreground="#94A3B8" FontSize="11"
                               FontWeight="SemiBold" 
                               Margin="0,0,0,14"/>

                    <UniformGrid Rows="1" Columns="5" Margin="0,0,0,24">

                        <!-- Card: Nuevo Registro -->
                        <Border Style="{StaticResource QuickCardStyle}"
        Cursor="Hand"
        MouseLeftButtonUp="CardNuevoRegistro_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#DDEDFE">
                                    <TextBlock Text="📄" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="#3979CD"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Nuevo Registro"
                                           FontWeight="SemiBold" FontSize="23"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Registrar una nueva audiencia o ejecución."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"
                                           TextWrapping="Wrap"/>

                            </Grid>
                        </Border>

                        <!-- Card: Consultar Registros -->
                        <Border Style = "{StaticResource QuickCardStyle}"
        Cursor="Hand"
        MouseLeftButtonUp="CardConsultar_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#DDF3E9">
                                    <TextBlock Text="🔍" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="#308879"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Consultar Registros"
                                           FontWeight="SemiBold" FontSize="23"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Buscar y consultar audiencias, ejecuciones y copias."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"
                                           TextWrapping="Wrap"/>

                            </Grid>
                        </Border>

                        <!-- Card: Registro de Copias -->
                        <Border Style="{StaticResource QuickCardStyle}"
        Cursor="Hand"
        MouseLeftButtonUp="CardCopias_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#E6DDFB">
                                    <TextBlock Text="◎" FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#7E65C9"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Registro de Copias"
                                           FontWeight="SemiBold" FontSize="23"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Registrar entrega de copias de audiencias."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"
                                           TextWrapping="Wrap"/>

                            </Grid>
                        </Border>

                        <!-- Card: Reportes -->
                        <Border Style="{StaticResource QuickCardStyle}"
        Cursor="Hand"
        MouseLeftButtonUp="CardReportes_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#FDEEDC">
                                    <TextBlock Text="📊" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="#E3A04A"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Reportes"
                                           FontWeight="SemiBold" FontSize="23"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Generar reportes y estadísticas del sistema."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"
                                           TextWrapping="Wrap"/>

                            </Grid>
                        </Border>

                        <!-- Card: Configuración -->
                        <Border Style="{StaticResource QuickCardStyle}"
        Cursor="Hand"
        MouseLeftButtonUp="CardConfiguracion_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#F0FDFA">
                                    <TextBlock Text="⚙" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#0D9488"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Configuración"
                                           FontWeight="SemiBold" FontSize="25"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Administrar parámetros del sistema."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"
                                           TextWrapping="Wrap"/>

                            </Grid>
                        </Border>
                    </UniformGrid>

                    <!-- ── LOWER TWO-COLUMN SECTION ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="450"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Resumen + Sistema -->
                        <StackPanel Grid.Column="0">

                            <!-- Resumen General -->
                            <TextBlock Text="RESUMEN GENERAL"
                                       Foreground="#94A3B8" FontSize="11"
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,14"/>

                            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">

                                <!-- Audiencias -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="50" Height="50" CornerRadius="12"
                                                Background="#2563EB" Margin="0,0,12,0">
                                            <TextBlock Text="⚖" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#EFF6FF"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TotalAudienciasMes}" FontSize="30"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Audiencias este mes"
                                                       FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Ejecuciones -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="50" Height="50" CornerRadius="12"
                                                Background="#16A34A" Margin="0,0,12,0">
                                            <TextBlock Text="✔" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#ECFDF5
"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TotalEjecucionesMes}" FontSize="30"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Ejecuciones este mes"
                                                       FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Copias -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="50" Height="50" CornerRadius="12"
                                                Background="#7C3AED" Margin="0,0,12,0">
                                            <TextBlock Text="◎" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#F5F3FF"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TotalCopiasMes}" FontSize="30"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Copias Entregadas este mes"
                                                       MaxWidth="140"
                                                       FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Audiencias hoy -->
                                <Border Style="{StaticResource StatCardStyle}" Margin="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="50" Height="50" CornerRadius="12"
                                                Background="#E3A04A" Margin="0,0,12,0">
                                            <TextBlock Text="📅" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="#FFF7ED"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AudienciasHoy}" FontSize="30"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Audiencias Hoy"
                                                       FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource SystemCardStyle}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Shield icon -->
                                    <Border Grid.Column="0" Width="60" Height="60"
                                            CornerRadius="30" Background="#EFF6FF"
                                            Margin="0,0,20,0">
                                        <TextBlock Text="🛡" FontSize="28"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Col 1 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="INFORMACIÓN DEL SISTEMA"
                                                   Foreground="#94A3B8" FontSize="10"
                                                   FontWeight="SemiBold"
                                                    Margin="0,0,0,8"/>
                                        <TextBlock Text="Versión del Sistema:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding VersionSistema}" Foreground="#2563EB"
                                                   FontWeight="SemiBold" FontSize="13" Margin="0,2,0,8"/>
                                        <TextBlock Text="Base de Datos:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding NombreBaseDatos}"
                                                   Foreground="#2563EB" FontSize="13"
                                                   FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Col 2 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                Margin="16,0,0,0">
                                        <TextBlock Text=" " FontSize="10" Margin="0,0,0,8"/>
                                        <TextBlock Text="Última Copia de Seguridad:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding UltimaCopiaSeguridad}"
                                                   Foreground="#2563EB" FontSize="13"
                                                   FontWeight="SemiBold" Margin="0,2,0,8"/>
                                        <TextBlock Text="Estado del Sistema:" Foreground="#64748B" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse Width="10" Height="10" Fill="#16A34A"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding EstadoSistema}" Foreground="#16A34A"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Información del Sistema -->
                        </StackPanel>

                        <!-- RIGHT: Actividad Reciente -->
                        <Border Grid.Column="2" Background="{DynamicResource CardBrush}"
BorderBrush="{DynamicResource BorderBrush}"
                                CornerRadius="12" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="12" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="ACTIVIDAD RECIENTE"
                                           Foreground="#94A3B8" FontSize="11"
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,14"/>

                                <!-- Table header -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="95"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="65"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fecha"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
           TextAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Actividad"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold"  HorizontalAlignment="Center"
           TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Usuario"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold"  HorizontalAlignment="Center"
           TextAlignment="Center"/>
                             
                                </Grid>
                                <Border Height="1" Background="#F1F5F9" Margin="0,0,0,6"/>

                                <!-- Rows -->
                                <ItemsControl ItemsSource="{Binding Actividades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Border
        Background="Transparent"
        Cursor="Hand"
        Padding="6"
        CornerRadius="6"
        MouseLeftButtonUp="Actividad_Click"
        MouseEnter="Actividad_MouseEnter"
        MouseLeave="Actividad_MouseLeave">

                                                <Grid>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Fecha -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Fecha}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="12"/>

                                                        <TextBlock Text="{Binding Hora}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11"/>
                                                    </StackPanel>

                                                    <!-- Actividad -->
                                                    <StackPanel Grid.Column="1">

                                                        <StackPanel Orientation="Horizontal">

                                                            <TextBlock Text="{Binding Icono}"
                               FontSize="14"
                               Margin="0,0,6,0"/>

                                                            <TextBlock Text="{Binding TipoActividad}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="12"/>

                                                        </StackPanel>

                                                        <TextBlock Text="{Binding Descripcion}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11"
                           Margin="20,2,0,0"/>

                                                    </StackPanel>

                                                    <!-- Usuario -->
                                                    <TextBlock Grid.Column="2"
                       Text="{Binding Usuario}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>

                                                </Grid>

                                            </Border>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1" Background="#F1F5F9" Margin="0,4,0,10"/>

                                <!-- Ver todas -->
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ver todas las actividades"
                                                   Foreground="#2563EB"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="  →" Foreground="#2563EB"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
