<Page x:Class="PoderJudicial.Views.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Poder Judicial Guatemala"
          UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="#F0F4F8"
        FontFamily="Segoe UI">

    <Page.Resources>
        <!-- ===== COLORS ===== -->
        <!-- SidebarBg: #1A2744 | AccentBlue: #2563EB | CardWhite: #FFFFFF -->
        <!-- TextDark: #1E293B  | TextMid: #64748B   | GreenStat: #16A34A -->
        <!-- OrangeStat: #EA580C | PurpleStat: #7C3AED | TealStat: #0D9488 -->

        

      

        <!-- ===== QUICK-ACCESS CARD STYLE ===== -->
        <Style x:Key="QuickCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                      BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STAT CARD STYLE ===== -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05"
                                      BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ICON CIRCLE STYLE ===== -->
        <Style x:Key="IconCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- ===== ARROW BUTTON ===== -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>
    </Page.Resources>

    



    <Grid>
        
        
        
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="17*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
           
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

       

        <!-- ══════════════════════════════════════════
             MAIN AREA
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <!-- Top bar -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════
         HEADER
     ══════════════════════════════════ -->

            <Border Grid.Row="0"
Background="{DynamicResource CardBrush}"
BorderThickness="0,0,0,1"
BorderBrush="{DynamicResource BorderBrush}"
Padding="32,18"
        Margin="0,0,0,30">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Home Page"
               FontSize="22"
               FontWeight="Bold"
               Foreground="{DynamicResource PrimaryTextBrush}"/>

                        <TextBlock Text="Sistema de control. by JJ"
               FontSize="12"
               Foreground="{DynamicResource SecondaryTextBrush}"
               Margin="0,3,0,0"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1"
            HorizontalAlignment="Right">

                        <TextBlock x:Name="TxtHora"
               FontSize="22"
               FontWeight="Bold"
               Foreground="{DynamicResource PrimaryTextBrush}"
               HorizontalAlignment="Right"/>

                        <TextBlock x:Name="TxtFecha"
               FontSize="12"
               Foreground="{DynamicResource SecondaryTextBrush}"
               HorizontalAlignment="Right"
               Margin="0,2,0,0"/>

                    </StackPanel>

                </Grid>

            </Border>



            <!-- ── SCROLLABLE CONTENT ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,24">

                    <!-- ── WELCOME BANNER ── -->
                    <Border CornerRadius="14" Margin="0,0,0,24" ClipToBounds="True">
                        <Grid>
                            <!-- Gradient background -->
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#EFF6FF" Offset="0"/>
                                        <GradientStop Color="#DBEAFE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left: text + accent bar -->
                                <Grid Grid.Column="0">
                                    <Border Width="4" Background="#2563EB"
                                            HorizontalAlignment="Left"
                                            CornerRadius="4,0,0,4"/>
                                    <StackPanel Margin="24,24,24,24">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="¡Bienvenido! " FontSize="26"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="👋" FontSize="26"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Sistema de gestión y control de audiencias, ejecuciones y copias."
                                                   Foreground="#475569" FontSize="14"
                                                   Margin="0,6,0,2"/>
                                        <TextBlock Text="Seleccione una opción del menú para comenzar."
                                                   Foreground="#475569" FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Right: courthouse illustration placeholder -->
                                <Border Grid.Column="1" Width="180" Height="120"
                                        Margin="0,0,24,0" VerticalAlignment="Center"
                                        Opacity="0.25">
                                    <TextBlock Text="🏛" FontSize="80"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── ACCESO RÁPIDO ── -->
                    <TextBlock Text="ACCESO RÁPIDO"
                               Foreground="#94A3B8" FontSize="11"
                               FontWeight="SemiBold" 
                               Margin="0,0,0,14"/>

                    <UniformGrid Rows="1" Columns="5" Margin="0,0,0,24">

                        <!-- Card: Nuevo Registro -->
                        <Border Style="{StaticResource QuickCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#EFF6FF">
                                    <TextBlock Text="📄" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Nuevo Registro"
                                           FontWeight="Bold" FontSize="16"
                                           Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Registrar una nueva audiencia o ejecución."
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Row="4" Style="{StaticResource ArrowButtonStyle}"
                                        Content="→" Foreground="#2563EB"/>
                            </Grid>
                        </Border>

                        <!-- Card: Consultar Registros -->
                        <Border Style="{StaticResource QuickCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#ECFDF5">
                                    <TextBlock Text="🔍" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Consultar Registros"
                                           FontWeight="SemiBold" FontSize="16"
                                           Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Buscar y consultar audiencias, ejecuciones y copias."
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Row="4" Style="{StaticResource ArrowButtonStyle}"
                                        Content="→" Foreground="#16A34A"/>
                            </Grid>
                        </Border>

                        <!-- Card: Registro de Copias -->
                        <Border Style="{StaticResource QuickCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#F5F3FF">
                                    <TextBlock Text="◎" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#7C3AED"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Registro de Copias"
                                           FontWeight="SemiBold" FontSize="16"
                                           Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Registrar entrega de copias de audiencias."
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Row="4" Style="{StaticResource ArrowButtonStyle}"
                                        Content="→" Foreground="#7C3AED"/>
                            </Grid>
                        </Border>

                        <!-- Card: Reportes -->
                        <Border Style="{StaticResource QuickCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#FFF7ED">
                                    <TextBlock Text="📊" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Reportes"
                                           FontWeight="SemiBold" FontSize="16"
                                           Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Generar reportes y estadísticas del sistema."
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Row="4" Style="{StaticResource ArrowButtonStyle}"
                                        Content="→" Foreground="#EA580C"/>
                            </Grid>
                        </Border>

                        <!-- Card: Configuración -->
                        <Border Style="{StaticResource QuickCardStyle}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource IconCircleStyle}"
                                        Background="#F0FDFA">
                                    <TextBlock Text="⚙" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#0D9488"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="Configuración"
                                           FontWeight="SemiBold" FontSize="16"
                                           Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Text="Administrar parámetros del sistema."
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
                                <Button Grid.Row="4" Style="{StaticResource ArrowButtonStyle}"
                                        Content="→" Foreground="#0D9488"/>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <!-- ── LOWER TWO-COLUMN SECTION ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="420"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Resumen + Sistema -->
                        <StackPanel Grid.Column="0">

                            <!-- Resumen General -->
                            <TextBlock Text="RESUMEN GENERAL"
                                       Foreground="#94A3B8" FontSize="11"
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,14"/>

                            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">

                                <!-- Audiencias -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="44" Height="44" CornerRadius="12"
                                                Background="#EFF6FF" Margin="0,0,12,0">
                                            <TextBlock Text="⚖" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#2563EB"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="124" FontSize="26"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="Audiencias este mes"
                                                       FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Ejecuciones -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="44" Height="44" CornerRadius="12"
                                                Background="#ECFDF5" Margin="0,0,12,0">
                                            <TextBlock Text="✔" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#16A34A"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="38" FontSize="26"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="Ejecuciones este mes"
                                                       FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Copias -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="44" Height="44" CornerRadius="12"
                                                Background="#F5F3FF" Margin="0,0,12,0">
                                            <TextBlock Text="◎" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7C3AED"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="76" FontSize="26"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="Copias Entregadas este mes"
                                                       FontSize="11" Foreground="#64748B"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Audiencias hoy -->
                                <Border Style="{StaticResource StatCardStyle}" Margin="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="44" Height="44" CornerRadius="12"
                                                Background="#FFF7ED" Margin="0,0,12,0">
                                            <TextBlock Text="📅" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="12" FontSize="26"
                                                       FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="Audiencias Hoy"
                                                       FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Información del Sistema -->
                            <Border Background="#FFFFFF" CornerRadius="12" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05"
                                                      BlurRadius="12" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Shield icon -->
                                    <Border Grid.Column="0" Width="60" Height="60"
                                            CornerRadius="30" Background="#EFF6FF"
                                            Margin="0,0,20,0">
                                        <TextBlock Text="🛡" FontSize="28"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Col 1 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="INFORMACIÓN DEL SISTEMA"
                                                   Foreground="#94A3B8" FontSize="10"
                                                   FontWeight="SemiBold"
                                                    Margin="0,0,0,8"/>
                                        <TextBlock Text="Versión del Sistema:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="1.0.0.0" Foreground="#2563EB"
                                                   FontWeight="SemiBold" FontSize="13" Margin="0,2,0,8"/>
                                        <TextBlock Text="Base de Datos:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="PoderJudicial.accdb"
                                                   Foreground="#2563EB" FontSize="13"
                                                   FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Col 2 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                Margin="16,0,0,0">
                                        <TextBlock Text=" " FontSize="10" Margin="0,0,0,8"/>
                                        <TextBlock Text="Última Copia de Seguridad:" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="23/05/2025  08:00 a. m."
                                                   Foreground="#2563EB" FontSize="13"
                                                   FontWeight="SemiBold" Margin="0,2,0,8"/>
                                        <TextBlock Text="Estado del Sistema:" Foreground="#64748B" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse Width="10" Height="10" Fill="#16A34A"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Operativo" Foreground="#16A34A"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- RIGHT: Actividad Reciente -->
                        <Border Grid.Column="2" Background="#FFFFFF"
                                CornerRadius="12" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="12" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="ACTIVIDAD RECIENTE"
                                           Foreground="#94A3B8" FontSize="11"
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,14"/>

                                <!-- Table header -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fecha"
                                               Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="Actividad"
                                               Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="Usuario"
                                               Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                </Grid>
                                <Border Height="1" Background="#F1F5F9" Margin="0,0,0,6"/>

                                <!-- Rows -->
                                <!-- Row 1 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="23/05/2025" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="10:32 a. m." Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Registro de audiencia"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Juan Pérez"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Row 2 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="23/05/2025" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="09:45 a. m." Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Entrega de copias"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="María López"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Row 3 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="22/05/2025" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="04:15 p. m." Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Registro de ejecución"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Carlos Ramírez"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Row 4 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="22/05/2025" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="11:20 a. m." Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Consulta de registros"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Ana Gómez"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Row 5 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="22/05/2025" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="09:05 a. m." Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Registro de audiencia"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Juan Pérez"
                                               Foreground="#475569" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Border Height="1" Background="#F1F5F9" Margin="0,4,0,10"/>

                                <!-- Ver todas -->
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ver todas las actividades"
                                                   Foreground="#2563EB"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="  →" Foreground="#2563EB"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
