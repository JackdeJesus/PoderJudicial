<Page x:Class="PoderJudicial.Views.EditarRegistro"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F3F4F6">

    <Page.Resources>


        <!-- ESTILOS -->

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">

            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Background" Value="#F7F7F7"/>
            <Setter Property="BorderBrush" Value="#2ECC8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2ECC8F"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

    </Page.Resources>

    <!-- ═══════════════════════════════ -->
    <!-- CONTENIDO -->
    <!-- ═══════════════════════════════ -->

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


       


        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="32,18">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>



                <!-- TITULO -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Editar Registro"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827" />

                    <TextBlock Text="Actualice la información del registro seleccionado."
                               FontSize="12"
                               Foreground="#6B7280"
                               Margin="0,3,0,0" />

                </StackPanel>

                <!-- FECHA -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">

                    <TextBlock x:Name="TxtHora"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Right"/>

                    <TextBlock x:Name="TxtFecha"
                               FontSize="12"
                               Foreground="#6B7280"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0"/>

                </StackPanel>

            </Grid>

        </Border>

       
        <!-- FORMULARIO -->
      

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <Border Background="White"
                    BorderBrush="#F3F4F6"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="36,32"
                    Margin="35,0,35,35">

                <StackPanel>

                    

                    <Grid Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ID -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Id"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtId"
                                     Style="{StaticResource InputStyle}"
                                     IsReadOnly="True"
                                     Background="#ECECEC"/>

                        </StackPanel>

                        <!-- No.causa -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="No. Causa"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtNoCausa"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                        <!-- NUC -->
                        <StackPanel Grid.Column="4">

                            <TextBlock Text="NUC"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtNUC"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                    </Grid>

                    <!-- separador -->
                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,20"/>

                 

                    <Grid Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- juzgado-->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Juzgado"
                                       Style="{StaticResource LabelStyle}"/>

                            <ComboBox x:Name="CmbJuzgado"
                                      Style="{StaticResource ComboStyle}">

                                <ComboBoxItem Content="Control"/>
                                <ComboBoxItem Content="Centro"/>
                                <ComboBoxItem Content="Otra..."/>

                            </ComboBox>

                        </StackPanel>

                        <!-- tipo Causa -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="Tipo Causa"
                                       Style="{StaticResource LabelStyle}"/>

                            <ComboBox x:Name="CmbTipoCausa"
                                      Style="{StaticResource ComboStyle}">

                                <ComboBoxItem Content="C"/>
                                <ComboBoxItem Content="CP"/>
                                <ComboBoxItem Content="JO"/>

                            </ComboBox>

                        </StackPanel>

                        <!-- sala -->
                        <StackPanel Grid.Column="4">

                            <TextBlock Text="Sala"
                                       Style="{StaticResource LabelStyle}"/>

                            <ComboBox x:Name="CmbSala"
                                      Style="{StaticResource ComboStyle}">

                                <ComboBoxItem Content="I"/>
                                <ComboBoxItem Content="II"/>
                                <ComboBoxItem Content="III"/>
                                <ComboBoxItem Content="IV"/>

                            </ComboBox>

                        </StackPanel>

                    </Grid>

                    <!-- SEPARADOR -->
                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,20"/>

                   

                    <Grid Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- IMPUTADO -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Imputado"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtImputado"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                        <!-- AGRAVIADO -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="Agraviado"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtAgraviado"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                    </Grid>

                    <!-- SEPARADOR -->
                    <Separator Background="#F3F4F6"
                               Margin="0,0,0,20"/>

                  

                    <Grid Margin="0,0,0,32">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- DELITO -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Delito"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtDelito"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                        <!-- TIPO AUDIENCIA -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="Tipo Audiencia"
                                       Style="{StaticResource LabelStyle}"/>

                            <TextBox x:Name="TxtTipoAudiencia"
                                     Style="{StaticResource InputStyle}"/>

                        </StackPanel>

                    </Grid>

                    
                    <!-- BOTONES -->
                   
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <!-- CANCELAR -->
                        <Button Content="Cancelar"
                                Width="140"
                                Height="44"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnCancelar_Click">

                            <Button.Template>

                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="BtnBorder"
                                            Background="#F3F4F6"
                                            CornerRadius="10">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver"
                                                 Value="True">

                                            <Setter TargetName="BtnBorder"
                                                    Property="Background"
                                                    Value="#E5E7EB"/>

                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>

                            </Button.Template>

                        </Button>

                        <!-- ACTUALIZAR -->
                        <Button Content="Actualizar Registro"
                                Width="190"
                                Height="44"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Click="BtnActualizar_Click">

                            <Button.Template>

                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="BtnBorder"
                                            Background="#2ECC8F"
                                            CornerRadius="10">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver"
                                                 Value="True">

                                            <Setter TargetName="BtnBorder"
                                                    Property="Background"
                                                    Value="#27B57D"/>

                                        </Trigger>

                                        <Trigger Property="IsPressed"
                                                 Value="True">

                                            <Setter TargetName="BtnBorder"
                                                    Property="Background"
                                                    Value="#1F9E6C"/>

                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>

                            </Button.Template>

                            <Button.Foreground>
                                White
                            </Button.Foreground>

                        </Button>

                    </StackPanel>

                </StackPanel>

            </Border>

        </ScrollViewer>

    </Grid>

</Page>