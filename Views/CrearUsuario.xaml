<Window x:Class="PoderJudicial.Views.CrearUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crear usuario" Height="482" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1A1F2E">

    <Window.Resources>
        <!-- Estilo campos de texto -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252B3B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2ECC8F"/>
            <Setter Property="BorderThickness" Value="0 0 0 1.5"/>
            <Setter Property="CaretBrush" Value="#2ECC8F"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Estilo PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#252B3B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2ECC8F"/>
            <Setter Property="BorderThickness" Value="0 0 0 1.5"/>
            <Setter Property="CaretBrush" Value="#2ECC8F"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Estilo labels -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A93A8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <!-- Estilo botón -->
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#2ECC8F"/>
            <Setter Property="Foreground" Value="#1A1F2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borde" Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borde" Property="Background" Value="#26A873"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borde" Property="Background" Value="#1E8F61"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="40 36 40 36">

        <!-- Encabezado -->
        <TextBlock Text="Crear usuario" FontSize="22" FontWeight="Bold"
                   Foreground="#FFFFFF" Margin="0 0 0 6"/>
        <TextBlock Text="Completa los campos para registrar un nuevo acceso."
                   FontSize="12" Foreground="#8A93A8" Margin="0 0 0 28"/>

        <!-- Usuario -->
        <TextBlock Text="USUARIO"/>
        <TextBox x:Name="txtUsuario" Margin="0 0 0 18"/>

        <!-- Contraseña -->
        <TextBlock Text="CONTRASEÑA"/>
        <PasswordBox x:Name="passNueva" Margin="0 0 0 18"/>

        <!-- Confirmar contraseña -->
        <TextBlock Text="CONFIRMAR CONTRASEÑA"/>
        <PasswordBox x:Name="passConfirmar" Margin="0 0 0 32"/>

        <!-- Botón -->
        <Button x:Name="btnCrear" Content="Crear usuario"
                Style="{StaticResource BtnPrimario}"
                Click="btnCrear_Click"/>

    </StackPanel>
</Window>