<Page x:Class="PoderJudicial.Views.ReportesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{DynamicResource BackgroundBrush}">

<Page.Resources>
    <SolidColorBrush x:Key="ContentBg"
                 Color="Transparent"/>

    <!-- ComboBox  -->
        <Style x:Key="FiltroCombo" TargetType="ComboBox">

            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ComboBox">

                        <Grid>

                            <!-- BOTÓN PRINCIPAL -->
                            <Border x:Name="Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- TEXTO -->
                                    <TextBlock Text="{TemplateBinding SelectionBoxItem}"
                             Margin="12,0,0,0"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left"
                             Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <!-- FLECHA -->
                                    <TextBlock Grid.Column="1"
                           Text="▼"
                           FontSize="10"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>


                                    <!-- BOTÓN -->
                                    <ToggleButton Grid.ColumnSpan="2"
                           Background="Transparent"
                           BorderThickness="0"
                           Focusable="False"
                           IsChecked="{Binding IsDropDownOpen,
                           RelativeSource={RelativeSource TemplatedParent},
                           Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>

                            </Border>

                            <!-- POPUP -->
                            <Popup x:Name="Popup"
               Placement="Bottom"
               AllowsTransparency="True"
               Focusable="False"
               IsOpen="{TemplateBinding IsDropDownOpen}"
               PopupAnimation="Slide">

                                <Border Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,4,0,0">

                                    <ScrollViewer MaxHeight="250">

                                        <StackPanel IsItemsHost="True"/>

                                    </ScrollViewer>

                                </Border>

                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush"
Value="{DynamicResource BorderBrush}"/>
                            </Trigger>


                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border"
                    Property="BorderBrush"
                    Value="#2ECC8F"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush"
Value="{DynamicResource BorderBrush}"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ── Estilo Item Combobox ── -->

        <Style TargetType="ComboBoxItem">

            <Setter Property="Foreground"
     Value="{DynamicResource PrimaryTextBrush}"/>

            <Setter Property="Background"
     Value="{DynamicResource CardBrush}"/>

            <Setter Property="Padding"
     Value="10,6"/>

            <Setter Property="FontSize"
     Value="13"/>

            <Style.Triggers>

                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background"
             Value="{DynamicResource HoverBrush}"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"
             Value="#2ECC8F"/>

                    <Setter Property="Foreground"
             Value="White"/>
                </Trigger>

            </Style.Triggers>

        </Style>



        <!-- Estilo del filtro -->
        <Style x:Key="FiltroLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground"
            Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Botón exportar Excel -->
    <Style x:Key="BtnExcel" TargetType="Button">
        <Setter Property="Height"          Value="40"/>
        <Setter Property="Padding"         Value="18,0"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Background"      Value="#2ECC8F"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#27B57D"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#1F9E6C"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón exportar PDF -->
    <Style x:Key="BtnPdf" TargetType="Button">
        <Setter Property="Height"          Value="40"/>
        <Setter Property="Padding"         Value="18,0"/>
        <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"
        Value="{DynamicResource PrimaryTextBrush}"/>

            <Setter Property="Background"
        Value="{DynamicResource CardBrush}"/>

            <Setter Property="BorderBrush"
        Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Page.Resources>

<Grid Background="{StaticResource ContentBg}">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
    <Border Grid.Row="0"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"                
                Padding="32,18">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Reportes"
                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Filtra y exporta registros de audiencias."
                               FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Botones exportar -->
            <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                <Button x:Name="BtnExportarExcel"
                            Style="{StaticResource BtnExcel}"
                            Margin="0,0,10,0"
                            Click="BtnExportarExcel_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇ " FontSize="13"/>
                        <TextBlock Text="Exportar Excel" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnExportarPdf"
                            Style="{StaticResource BtnPdf}"
                            Click="BtnExportarPdf_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📄 " FontSize="13"/>
                        <TextBlock Text="Exportar PDF" FontSize="13"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>
    </Border>

    <!-- CONTENIDO -->
    <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">

            <!-- ── FILTROS ── -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="28,22"
                        Margin="0,0,0,20">
                <StackPanel>

                    <!-- Título filtros -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="⧗ " FontSize="15" Foreground="#2ECC8F"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Filtros"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- FILA DE FILTROS: Mes / Año / Juzgado / Tipo Causa / Sala -->
                        <!-- FILA DE FILTROS: Tipo Causa / Mes / Año / Juzgado / Sala -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- TIPO CAUSA -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tipo Causa" Style="{StaticResource FiltroLabel}"/>
                                <ComboBox x:Name="CmbTipoCausa"
                  Style="{StaticResource FiltroCombo}"
                  SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="C"/>
                                    <ComboBoxItem Content="CP"/>
                                    <ComboBoxItem Content="JO"/>
                                    <ComboBoxItem Content="XP"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- MES -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mes" Style="{StaticResource FiltroLabel}"/>
                                <ComboBox x:Name="CmbMes"
                  Style="{StaticResource FiltroCombo}"
                  SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Enero"/>
                                    <ComboBoxItem Content="Febrero"/>
                                    <ComboBoxItem Content="Marzo"/>
                                    <ComboBoxItem Content="Abril"/>
                                    <ComboBoxItem Content="Mayo"/>
                                    <ComboBoxItem Content="Junio"/>
                                    <ComboBoxItem Content="Julio"/>
                                    <ComboBoxItem Content="Agosto"/>
                                    <ComboBoxItem Content="Septiembre"/>
                                    <ComboBoxItem Content="Octubre"/>
                                    <ComboBoxItem Content="Noviembre"/>
                                    <ComboBoxItem Content="Diciembre"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- AÑO -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Año" Style="{StaticResource FiltroLabel}"/>
                                <ComboBox x:Name="CmbAnio"
                  Style="{StaticResource FiltroCombo}"
                  SelectionChanged="Filtro_Changed"/>
                            </StackPanel>

                            <!-- JUZGADO -->
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Juzgado" Style="{StaticResource FiltroLabel}"/>
                                <ComboBox x:Name="CmbJuzgado"
                  Style="{StaticResource FiltroCombo}"
                  SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Control"/>
                                    <ComboBoxItem Content="Centro"/>
                                    <ComboBoxItem Content="Otra..."/>
                                </ComboBox>
                            </StackPanel>

                            <!-- SALA -->
                            <StackPanel Grid.Column="8">
                                <TextBlock Text="Sala" Style="{StaticResource FiltroLabel}"/>
                                <ComboBox x:Name="CmbSala"
                  Style="{StaticResource FiltroCombo}"
                  SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todas" IsSelected="True"/>
                                    <ComboBoxItem Content="I"/>
                                    <ComboBoxItem Content="II"/>
                                    <ComboBoxItem Content="III"/>
                                    <ComboBoxItem Content="IV"/>
                                </ComboBox>
                            </StackPanel>

                        </Grid>


                    </StackPanel>
            </Border>

            <!-- ── RESUMEN ── -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="28,18"
                        Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">

                    <!-- Registros encontrados -->
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Registros encontrados"
                                       FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="TxtTotalRegistros"
                                       Text="0"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <!-- Separador vertical -->
                    <Border Width="1" Background="#E5E7EB" Margin="0,4,40,4"/>

                    <!-- Total discos -->
                    <StackPanel>
                        <TextBlock Text="Total de Discos"
                                       FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="12" Height="12"
                                         Fill="#2ECC8F"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtTotalDiscos"
                                           Text="0"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ── TABLA RESULTADOS ── -->
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True"
                        Padding="0,0,0,0">
                <StackPanel>

                    <TextBlock Text="Resultados"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="24,20,24,16"/>

                    <DataGrid x:Name="DgResultados"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Background="{DynamicResource CardBrush}"
                                  RowBackground="{DynamicResource CardBrush}"
                                  AlternatingRowBackground="{DynamicResource AltRowBrush}"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  RowHeight="52"
                                  ColumnHeaderHeight="46"
                                  FontSize="12"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="420">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="FontSize"        Value="12"/>
                                <Setter Property="Padding"         Value="12,0"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="FlowDirection"   Value="LeftToRight"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness"  Value="0"/>
                                <Setter Property="Padding"          Value="12,0"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FlowDirection"    Value="LeftToRight"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Fecha Audiencia"      Width="150" Binding="{Binding FechaAudiencia}"/>
                            <DataGridTextColumn Header="Juzgado"              Width="120" Binding="{Binding Juzgado}"/>
                            <DataGridTextColumn Header="Juez"                 Width="180" Binding="{Binding Juez}"/>
                            <DataGridTextColumn Header="No. Causa"            Width="130" Binding="{Binding NoCausa}"/>
                            <DataGridTextColumn Header="NUC"                  Width="160" Binding="{Binding NUC}"/>
                            <DataGridTextColumn Header="Tipo Audiencia"       Width="160" Binding="{Binding TipoAudiencia}"/>
                            <DataGridTextColumn Header="Tipo Causa"           Width="120" Binding="{Binding TipoCausa}"/>
                            <DataGridTextColumn Header="Sala"                 Width="80"  Binding="{Binding Sala}"/>
                            <DataGridTextColumn Header="Imputado"             Width="200" Binding="{Binding Imputado}"/>
                            <DataGridTextColumn Header="Agraviado"            Width="200" Binding="{Binding Agraviado}"/>
                            <DataGridTextColumn Header="Delito"               Width="200" Binding="{Binding Delito}"/>
                            <DataGridTextColumn Header="No. Causa Juicio"     Width="150" Binding="{Binding NoCausaJuicio}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Grid>

</Page>