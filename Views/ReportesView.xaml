<Window x:Class="PoderJudicial.Views.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoderJudicial.Views"
        mc:Ignorable="d"
        Title="Window1"
        Height="450"
        Width="800">

    <Window.Resources>

        <SolidColorBrush x:Key="ContentBg" Color="#F3F4F6"/>

    </Window.Resources>

    <Grid Background="{StaticResource ContentBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ ENCABEZADO ═══════════════ -->

        <Border Grid.Row="0"
                Background="White"
                BorderThickness="0,0,0,1"
                BorderBrush="#E5E7EB"
                Padding="32,18">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título -->

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">

                    <TextBlock Text="Reportes"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    <TextBlock Text="Bienvenido, Admin Sistema. Visualiza y administra los reportes del sistema."
                               FontSize="12"
                               Foreground="#6B7280"
                               Margin="0,3,0,0"/>

                </StackPanel>

                <!-- Hora -->

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <TextBlock x:Name="TxtHora"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Right"/>

                    <TextBlock x:Name="TxtFecha"
                               FontSize="12"
                               Foreground="#6B7280"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0"/>

                </StackPanel>

            </Grid>

        </Border>

        <!--  CONTENIDO -->

        <Border Grid.Row="1"
                Background="{StaticResource ContentBg}"/>

    </Grid>

</Window>