<Page x:Class="PoderJudicial.Views.ConsultarRegistros"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PoderJudicial.Views"
      mc:Ignorable="d"
      Background="#F3F4F6"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">

   
    <Page.Resources>

        <SolidColorBrush x:Key="ContentBg" Color="#F3F4F6"/>

        <!-- Estilo badge tipo audiencia -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Estilo botón acción -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                x:Name="btn">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="{StaticResource ContentBg}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER-->

        <Border Grid.Row="0"
                Background="White"
                BorderThickness="0,0,0,1"
                BorderBrush="#E5E7EB"
                Padding="32,18">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Consultar Registros"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    <TextBlock Text="Bienvenido, Admin Sistema. Visualiza y gestiona los registros de audiencias."
                               FontSize="12"
                               Foreground="#6B7280"
                               Margin="0,3,0,0"/>

                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">

                    <TextBlock x:Name="TxtHora"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Right"/>

                    <TextBlock x:Name="TxtFecha"
                               FontSize="12"
                               Foreground="#6B7280"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ══════════════════════════════════
             CONTENIDO
        ══════════════════════════════════ -->

        <Grid Grid.Row="1"
              Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ BUSCADOR ═══ -->

            <Grid Grid.Row="0"
                  Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Campo buscar -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Height="42">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="⌕"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#9CA3AF"/>

                        <TextBox x:Name="txtBuscar"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 Foreground="#374151"
                                 VerticalContentAlignment="Center"
                                 Padding="0,0,10,0">

                            <!-- Placeholder -->
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="PlaceholderBrush"
                                                     AlignmentX="Left"
                                                     AlignmentY="Center"
                                                     Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Buscar por causa, NUC, imputado, agraviado..."
                                                           Foreground="#9CA3AF"
                                                           FontSize="13"
                                                           Margin="0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background"
                                                    Value="{StaticResource PlaceholderBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>

                        </TextBox>

                    </Grid>

                </Border>

                <!-- Total registros -->
                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="14,7">

                    <TextBlock x:Name="txtTotalRegistros"
                               Text="0 registro(s) encontrado(s)"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#374151"/>

                </Border>

            </Grid>

            <!-- ═══ TABLA ═══ -->

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    ClipToBounds="True">

                <DataGrid x:Name="dgAudiencias"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          CanUserResizeRows="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeight="56"
                          ColumnHeaderHeight="52"
                          FontSize="13"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          FrozenColumnCount="1">

                    <!-- ── Estilo Header ── -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Height" Value="52"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- ── Estilo Filas ── -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="#F3F4F6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- ── Estilo Celdas ── -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <!-- columnas -->
                       
                 

                    <DataGrid.Columns>

                        <!-- No. Causa -->
                        <DataGridTextColumn Header="No. Causa"
                                            Width="150"
                                            Binding="{Binding NoCausa}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- NUC -->
                        <DataGridTextColumn Header="NUC"
                                            Width="160"
                                            Binding="{Binding NUC}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Fecha Audiencia -->
                        <DataGridTextColumn Header="Fecha Audiencia"
                                            Width="140"
                                            Binding="{Binding FechaAudiencia}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Tipo Audiencia (badge) -->
                        <DataGridTemplateColumn Header="Tipo Audiencia"
                                                Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource BadgeStyle}">
                                        <TextBlock Text="{Binding TipoAudiencia}"
                                                   FontSize="12"
                                                   Foreground="#374151"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Juzgado -->
                        <DataGridTextColumn Header="Juzgado"
                                            Width="200"
                                            Binding="{Binding Juzgado}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Imputado -->
                        <DataGridTextColumn Header="Imputado"
                                            Width="200"
                                            Binding="{Binding Imputado}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Sala -->
                        <DataGridTextColumn Header="Sala"
                                            Width="130"
                                            Binding="{Binding Sala}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- ── ACCIONES (frozen derecha) ── -->
                        <DataGridTemplateColumn Header="Acciones"
                                                Width="120"
                                                CanUserSort="False"
                                                CanUserResize="False">

                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Height" Value="52"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <!-- Ver -->
                                        <Button x:Name="BtnVer" Style="{StaticResource ActionBtnStyle}"
                                                ToolTip="Ver detalle" Click="BtnVer_Click">
                                            <TextBlock Text="👁"
                                                       FontSize="15"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Button>

                                        <!-- Editar -->
                                        <Button x:Name="BtnEditar" Style="{StaticResource ActionBtnStyle}"
                                                ToolTip="Editar registro" Click="BtnEditar_Click">
                                            <TextBlock Text="✏"
                                                       FontSize="15"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Button>

                                        

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>

</Page>