<Page x:Class="PoderJudicial.Views.ConsultarRegistros"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#F3F4F6">

    <Page.Resources>

        <SolidColorBrush x:Key="ContentBg" Color="#F3F4F6"/>

        <!-- Badge -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background"          Value="#F3F4F6"/>
            <Setter Property="CornerRadius"         Value="6"/>
            <Setter Property="Padding"              Value="10,4"/>
            <Setter Property="HorizontalAlignment"  Value="Left"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
        </Style>

        <!-- Botones acción -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="{StaticResource ContentBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="32,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Consultar Registros"
                               FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Bienvenido, Admin Sistema. Visualiza y gestiona los registros."
                               FontSize="12" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Hora desde ViewModel -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Hora}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#111827" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Fecha}"
                               FontSize="12" Foreground="#6B7280"
                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BUSCADOR -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White" BorderBrush="#D1D5DB"
                        BorderThickness="1" CornerRadius="10" Height="42">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="⌕" FontSize="14" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Grid Grid.Column="1">
                            <TextBox x:Name="txtBuscar"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="13"
                                     Foreground="Gray"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     TextChanged="txtBuscar_TextChanged"
                                     KeyUp="txtBuscar_KeyUp"
                                     GotFocus="txtBuscar_GotFocus"
                                     LostFocus="txtBuscar_LostFocus"/>

                            <Popup x:Name="popupSugerencias"
                                   PlacementTarget="{Binding ElementName=txtBuscar}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#D1D5DB"
                                        BorderThickness="1" CornerRadius="8"
                                        Width="360" MaxHeight="220">
                                    <ListBox x:Name="lstSugerencias"
                                             BorderThickness="0"
                                             FontSize="13"
                                             MouseUp="lstSugerencias_MouseUp"
                                             KeyDown="lstSugerencias_KeyDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10"/>
                                                <Setter Property="Cursor"  Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F3F4F6"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Total desde ViewModel -->
                <Border Grid.Column="1"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="White" CornerRadius="8"
                        BorderBrush="#E5E7EB" BorderThickness="1" Padding="14,7">
                    <TextBlock Text="{Binding TotalRegistros}"
                               FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                </Border>
            </Grid>

            <!-- TABLA -->
            <Border Grid.Row="1"
                    Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="16" ClipToBounds="True">
                <DataGrid x:Name="dgAudiencias"
          ItemsSource="{Binding Audiencias}"
          AutoGenerateColumns="False"
          FlowDirection="RightToLeft"
          FrozenColumnCount="1"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          BorderThickness="0"
          Background="White"
          RowBackground="White"
          AlternatingRowBackground="#FAFAFA"
          CanUserResizeRows="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserSortColumns="True"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          IsReadOnly="True"
          RowHeight="56"
          ColumnHeaderHeight="52"
          FontSize="13"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto">

                    <!-- ═══ ESTILOS INTERNOS ═══ -->
                    <DataGrid.Resources>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Setter Property="Focusable" Value="False"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#F9FAFB"/>
                            <Setter Property="Foreground"      Value="#111827"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="FontSize"        Value="13"/>
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <!-- Corrige orientación de todos los headers -->
                            <Setter Property="FlowDirection"   Value="LeftToRight"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush"      Value="#F3F4F6"/>
                            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
                            <Setter Property="Cursor"           Value="Hand"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness"   Value="0"/>
                            <Setter Property="Padding"           Value="12,0"/>
                            <Setter Property="Foreground"        Value="#111827"/>
                            <Setter Property="Background"        Value="Transparent"/>
                            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <!-- Corrige orientación de todas las celdas -->
                            <Setter Property="FlowDirection"     Value="LeftToRight"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <!-- ═══ COLUMNAS ═══ -->
                    <DataGrid.Columns>

                        <!-- ACCIONES — va PRIMERO porque FrozenColumnCount=1 congela desde la derecha -->
                        <DataGridTemplateColumn Header="Acciones"
                                Width="120"
                                CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                                        <Button Style="{StaticResource ActionBtnStyle}"
                                ToolTip="Ver detalle"
                                Command="{Binding DataContext.VerCommand,
                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                                            <TextBlock Text="👁" FontSize="15"/>
                                        </Button>

                                        <Button Style="{StaticResource ActionBtnStyle}"
                                ToolTip="Editar"
                                Command="{Binding DataContext.EditarCommand,
                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                                            <TextBlock Text="✏" FontSize="15"/>
                                        </Button>

                                        <Button Style="{StaticResource ActionBtnStyle}"
                                ToolTip="Eliminar registro"
                                Command="{Binding DataContext.EliminarCommand,
                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                                            <TextBlock Text="🗑" FontSize="15" Foreground="#DC2626"/>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- RESTO DE COLUMNAS (orden original) -->
                        <DataGridTextColumn Header="No. Causa"    Width="150" Binding="{Binding NoCausa}"/>
                        <DataGridTextColumn Header="NUC"          Width="160" Binding="{Binding NUC}"/>
                        <DataGridTextColumn Header="Fecha Audiencia"  Width="140" Binding="{Binding FechaAudiencia}"/>
                        <DataGridTextColumn Header="Fecha Recibido"   Width="140" Binding="{Binding FechaRecibo}"/>
                        <DataGridTextColumn Header="Tipo Causa"       Width="150" Binding="{Binding TipoCausa}"/>

                        <!-- TIPO AUDIENCIA (badge) -->
                        <DataGridTemplateColumn Header="Tipo Audiencia" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource BadgeStyle}">
                                        <TextBlock Text="{Binding TipoAudiencia}"
                                   FontSize="12"
                                   Foreground="#374151"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Juzgado"              Width="200" Binding="{Binding Juzgado}"/>
                        <DataGridTextColumn Header="Juez"                 Width="180" Binding="{Binding Juez}"/>
                        <DataGridTextColumn Header="Imputado"             Width="220" Binding="{Binding Imputado}"/>
                        <DataGridTextColumn Header="Delito"               Width="220" Binding="{Binding Delito}"/>
                        <DataGridTextColumn Header="Agraviado"            Width="220" Binding="{Binding Agraviado}"/>
                        <DataGridTextColumn Header="Sala"                 Width="130" Binding="{Binding Sala}"/>
                        <DataGridTextColumn Header="Hora Conclusión"      Width="150" Binding="{Binding HoraConclusion}"/>
                        <DataGridTextColumn Header="No. Causa Juicio"     Width="180" Binding="{Binding NoCausaJuicio}"/>
                        <DataGridTextColumn Header="Total Discos"         Width="140" Binding="{Binding TotDiscos}"/>
                        <DataGridTextColumn Header="Tipo Disco"           Width="150" Binding="{Binding TipoDisco}"/>
                        <DataGridTextColumn Header="Total Disco Audiencia" Width="180" Binding="{Binding TotDiscoAudiencia}"/>
                        <DataGridTextColumn Header="Quien Realiza"        Width="180" Binding="{Binding QuienRealiza}"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </Grid>
    </Grid>
</Page>