<Window x:Class="PoderJudicial.Views.VerDetalleRegistro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Detalle del Registro"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground"
            Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="ValorStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Foreground"
            Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
        Background="{DynamicResource CardBrush}"
        Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="45"
                  ShadowDepth="10"
                  Color="#000000"
                  Opacity="0.85"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
        CornerRadius="8,8,0,0"
        Background="{DynamicResource CardBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Detalle del Registro"
                               FontFamily="Segoe UI Semibold"
                               FontSize="17"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="24,0,0,0"/>
                    <Button x:Name="BtnCerrar"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"
                            Width="28" Height="28"
                            FontSize="13"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Cursor="Hand" Click="BtnCerrar_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border"
        Property="Background"
        Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENIDO -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24,16,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ID / NO. CAUSA -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ID" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtID" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="NO. CAUSA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtNoCausa" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- NUC / FECHA AUDIENCIA -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NUC" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtNUC" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="FECHA AUDIENCIA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtFechaAudiencia" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- FECHA RECIBO / HORA CONCLUSIÓN -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="FECHA RECIBO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtFechaRecibo" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="HORA CONCLUSIÓN" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtHoraConclusion" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- TIPO AUDIENCIA / TIPO CAUSA -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TIPO AUDIENCIA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTipoAudiencia" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TIPO CAUSA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTipoCausa" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- JUZGADO / JUEZ -->
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="JUZGADO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtJuzgado" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="JUEZ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtJuez" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- SALA / TOTAL DISCOS -->
                    <Grid Grid.Row="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SALA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtSala" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TOTAL DISCOS" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTotalDiscos" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- TIPO DISCO / TOTAL DISCO AUDIENCIA -->
                    <Grid Grid.Row="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TIPO DISCO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTipoDisco" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TOTAL DISCO AUDIENCIA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTotalDiscoAudiencia" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- IMPUTADO / DELITO -->
                    <Grid Grid.Row="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="IMPUTADO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtImputado" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="DELITO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtDelito" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- AGRAVIADO / NO. CAUSA JUICIO -->
                    <Grid Grid.Row="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AGRAVIADO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtAgraviado" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="NO. CAUSA JUICIO" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtNoCausaJuicio" Text="-" Style="{StaticResource ValorStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- DIFERIDA / QUIEN REALIZA -->
                    <Grid Grid.Row="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="QUIEN REALIZA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtQuienRealiza" Text="-" Style="{StaticResource ValorStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>